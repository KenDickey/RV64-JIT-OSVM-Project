t: 2r0010111 "auipc opcode - U format"					+ X1 << 7 "X1 is ReturnAddr = Link"					+ (offset bitAnd:  16rFFFFF000). "offset less lower 12 bits"	machineCode at: 1				put:  2r1100111 "jalr opcode - I Format"					+ X1 << 7					"+ (0 << 12) 'func3'"					+ X1 << 15					+ (offset bitAnd:  16r00000FFF) << 20. "offset lower 12 bits"	^8	! !!CogRV64Compiler methodsFor: 'generate machine code - concretize' stamp: 'KenD 7/18/2026 15:10'!concretizeJumpLong	"jl 20 bit offset -> jal x0 offset"	<inline: true>	| offset |	offset := (operands at: 0) - address.	self assert: ((offset bitAnd: 16rFFFFF) = offset). "20 bit offset"	machineCode		at: 0		put: 2r101111 "jal opcode - J Format"		"J Format: immediate is [20|10:1|11|19:2] to min CPU decode logic"			+ ((offset bitAnd: 2r010000000000000000000) << 11) "sign"			+( (offset bitAnd: 2r000000000001111111111) << 20)			+ ((offset  bitAnd: 2r000000000010000000000) << 9)			+ ((offset bitAnd: 2r001111111100000000000) << 0).	^4! !!CogRV64Compiler methodsFor: 'generate machine code - concretize' stamp: 'KenD 7/18/2026 15:09'!concretizeJumpR	"jr reg => jalr x0 reg 0"	<inline: true>	machineCode		at: 0		put: 2r1100111 "jalr opcode - I Format"			"+ (0 << 12) 'func3'"			+ ((operands at: 0) << 7). "reg"	^4! !"-- -- -- -- -- -- -- -- -- -- -- -- -- -- -- -- -- -- "!CogRV64Compiler class	instanceVariableNames: ''!!CogRV64Compiler class methodsFor: 'class initialization' stamp: 'KenD 7/8/2026 17:15'!initialize"	RV64G Constants"		#( 	( BEQ BNE BLT BGE BLTU BGEU ). "Branch Comnditionals"	"32 Integer Registers"	(X0 X1 X2 X3 X4 X5 X6 X7 X8 X9 X10 X11 X12 X13 X14 X15 X16	 X17 X18 X19 X29 X21 X22 X23 X24 X25 X26 X27 X28 X29 X30 X31)	"32 Double Float Registers"	(F0 F1 F2 F3 F4 F5 F6 F7 F8 F9 F10 F11 F12 F13 F14 F15 F16	 F17 F18 F19 F29 F21 F22 F23 F24 F25 F26 F27 F28 F29 F30 F31)	"Float Data Formats"	(SizeSingle "=32 bits" 	SizeDouble "=64 bits" 	SizeHalf  "=16 bits" 	SizeQuad "=128 bits")   	"Float Rounding Modes"	(RoundNearestToEven "RME Round to Nearest, ties to Even"	RoundTwordZero          "RTZ Round Towards Zero"	RoundDown                  "RDN Round DowN (toward -infinity)"	RoundUp                      "RUP Round UP (towards +infinity)"	RoundNearestToMax   "RMM Round to nearest, ties to Max Magnitude"	Round1Reserved	Round2Reserved	DYNamic  "DYN In instructions #rm field, select dynamic; else illegal")	)  do:		[:classVarNames|		 classVarNames withIndexDo:			[:k :v|			CogRV64Compiler classPool at: k put: v - 1]].	self initilizeRV64RegisterAliases "NB: Invokes initializeAbstractRegisters" ! !!CogRV64Compiler class methodsFor: 'class initialization' stamp: 'KenD 7/15/2026 12:30'!initializeAbstractRegisters	"Assign the abstract registers with the identities/indices of the	 relevant concrete registers,	 and assign CallerSavedRegisterMask appropriately.		 NOTA BENE: Smalltalk Stack Pointer Regsister is _*NOT*_ same 	as the C/ABI Stack Register as separate stacks are used.		Smalltalk Registers are typically designated CalleE Saved in the ABI."		Arg0Reg			:= Arg0.	Arg1Reg			:= Arg1.	"Arg2 Arg3 Arg4"	ClassReg			:= Arg5.	ReceiverResultReg	:= Arg6.	SendNumArgsReg	:= Arg7.			ABIResultReg		:= Arg0. 	ABIResultRegHigh	:= Arg1.				TempReg			:= Tmp3.	RISCTempReg		:= Tmp4.	TempAddr 			:= Tmp5.  "Used to construct jumps/calls with auipc"	TempConditions	:= Tmp6.  "Set Condition codes for conditional jumps"	FPReg				:= FramePtr.	SPReg				:= Sav10.  "Smalltalk SP; ISA StackPtr reg is X2"	VarBaseReg			:= Sav11.		LinkReg			:= ReturnAddr. "X1"					NativeSPReg		:= StackPtr.	CallerSavedRegisterMask := 		ABICallerSavedRegisterMask  "Use Temps rather than Saves???"			bitAnd: (self registerMaskFor: ClassReg 										and: ReceiverResultReg 										and: SendNumArgsReg 										and: Arg0Reg 										and: Arg1Reg 										and: SPReg).	"Sav0 is C StackPointer"				Extra0Reg			:= Sav1. "CalleE saved"	Extra1Reg			:= Sav2.	Extra2Reg			:= Sav3.	Extra3Reg			:= Sav4.	Extra4Reg			:= Sav5.	Extra5Reg			:= Sav6.	Extra6Reg			:= Sav7.	Extra7Reg			:= Sav8.	Extra8Reg			:= Sav9.	"Sav10 for Smalltalk SP,	 Sav11 for VarBaseReg."									CArg0Reg := Arg0.	CArg1Reg := Arg1.	CArg2Reg := Arg2.	CArg3Reg := Arg3.	CArg4Reg := Arg4.	CArg5Reg := Arg5.	CArg6Reg := Arg6.	CArg7Reg := Arg7.	NumRegisters := 32.	DPFPReg0		:= F0. "Temp regs F0..7"	DPFPReg1		:= F1.	DPFPReg2		:= F2.	DPFPReg3		:= F3.	DPFPReg4		:= F4.	DPFPReg5		:= F5.	DPFPReg6		:= F6.	DPFPReg7		:= F7.	"Float Arg Regs: Farg0..7 = F10..17"	DPFPReg8		:= F28. "Temp regs F28..31"	DPFPReg9		:= F29.	DPFPReg10		:= F30.	DPFPReg11		:= F31.	"@@Revisit@@"	DPFPReg12		:= FArg0.	DPFPReg13		:= FArg1.	DPFPReg14		:= FArg2.	DPFPReg15		:= FArg3.	NumFloatRegisters := 32! !!CogRV64Compiler class methodsFor: 'class initialization' stamp: 'KenD 7/9/2026 12:48'!initilizeRV64RegisterAliases		Zero := X0. 	ReturnAddr := X1. "R=calleR saves"	StackPtr	 := X2. "E=calleE saves" 	GlobalPtr	 := X3. 	ThreadPtr	 := X4. 	Tmp0 := X5. "R" 	Tmp1 := X6. "R" 	Tmp2 := X7. "R" 	FramePtr := Sav0 := X8. "E" 	Sav1 :=  X9.  "E"	Arg0 := X10. "R"	Arg1 := X11. "R"	Arg2 := X12. "R"	Arg3 := X13. "R"	Arg4 := X14. "R"	Arg5 := X15. "R"	Arg6 := X16. "R"	Arg7 := X17. "R"	Sav2  := X18.  "E"	Sav3  := X19.  "E"	Sav4  := X20.  "E"	Sav5  := X21.  "E"	Sav6  := X22.  "E"	Sav7  := X23.  "E"	Sav8  := X24.  "E"	Sav9  := X25.  "E"	Sav10 := X26.  "E"	Sav11 := X27.  "E"	Tmp3  := X28. "R"	Tmp4  := X29. "R"	Tmp5  := X30. "R"	Tmp6  := X31. "R"		FTmp0 := F0. "R"	FTmp1 := F1. "R"	FTmp2 := F2. "R"	FTmp3 := F3. "R"	FTmp4 := F4. "R"	FTmp5 := F5. "R"	FTmp6 := F6. "R"	FTmp7 := F7. "R"	FSav0  := F8. "E"	FSav1  := F9."E"	FArg0 := F10. "R"	FArg1 := F11. "R"	FArg2 := F12. "R"	FArg3 := F13. "R"	FArg4 := F14. "R"	FArg5 := F15. "R"	FArg6 := F16. "R"	FArg7 := F17. "R"	FSav2 := F18. "E"	FSav3 := F19. "E"	 FSav4 := F20. "E"	FSav5 := F21. "E"	FSav6 := F22. "E"	FSav7 := F23. "E"	FSav8 := F24. "E"	FSav9 := F25. "E"	FSav10  := F26. "E"	FSav11  := F27. "E"	FTmp8   := F28. "R"	FTmp9   := F29. "R"	FTmp10 := F30. "R"	FTmp11 := F31. "R"		ABICalleeSavedRegisterMask := 		(self registerMaskFor: X2 and: X8 and: X9 and: X10 and: X18)		+ (self registerMaskFor: X19 and: X20 and: X21 and: X22 and: X23)		+ (self registerMaskFor: X24 and: X25 and: X26 and: X27 and: X23).										ABICallerSavedRegisterMask := 		((self registerMaskFor: X0 and: X5 and: X6 and: X7)		+ (self registerMaskFor: X10 and: X11 and: X12 and: X13 and: X14 and: X15)		+ (self registerMaskFor: X16 and: X17 and: X28 and: X29 and: X30 and: X31)).											self initializeAbstractRegisters  "Also sets CallerSavedRegisterMask"	! !!CogRV64Compiler class methodsFor: 'documentation' stamp: 'KenD 7/5/2026 12:18'!callingC^' RV64G = General [IMAFD = Integer/Multiply/Atomic/Float/DoubleFloat]- Little Endian; 64 bit = 8 byte registers- Instruction size is 32 bits [except RV64C = Compact; not done here]- Stack Grows Down; 16 byte (quad word) aligned; low 4 addr bits are zero**  RV64G Calling Convention- Arguments: Up to 8 integer [A0-A7] and 8 floats [FA0-FA7] in registers- Args smaller than a register are passed in the lest-significant bits- When args are twice the size of a register, they are passed on the stack,and are naturally aligned. - Args more than twice register size are passed by reference.- If args are thought of as a C struct with pointer aligned fields, the are regs are a shadowof the 1st 8 pointer-words of the struct. If arg index i < 8 are floats, they are passedin the corresponding float register [FAi vs Ai]. HOWEVER, float args which are part ofa union  or array are passed in the integer registers, as are args to variadic functions.- Args beyond 8 are passed on the stack with SP pointing to the first arg not passedin a register.- Ints smaller than register size are sign extended in upper bits** RETURN VALUES- integers in A0/A1, floats in FA0/FA1. BUT float returns in float regs ONLY if prim or part of a result consisting of 1 or 2 float values, OTHERWISE in integer regs.- Larger returns are passed in memory which is allocated by the caller andthe pointer address passed as an implicit first parameter of the callee.x0 = ZERO [hardwired]x1 = Return Addressx2 = Stack Pointerx8 = Frame Pointerx3 = Globals Pointerx4 = Thread Pointerx10..x17 = A0..A7    Integer Args ; A0..A1 return valuesf10..f17 = FA0..FA7  Float Args;  FA0..FA1 return valuessize in 	  Cbytes	Type===	===  1		char  2		short  4		int  8		long    [Nota Bene: 4 bytes in RV32]  8		long long  8		void*  4		float  8		double 16		long double'! !!CogRV64Compiler class methodsFor: 'documentation' stamp: 'KenD 7/16/2026 11:59'!learnMe	^'I do Cog JIT for RV64G (riscv64 General) processorsIn addition to my (CogRV64Compiler) code, pease read:RV64G Instruction Formats at riscv.org: 	https://docs.riscv.org/reference/home/index.html	 #RegisterAllocatingCogit and superclasses #CogRTLOpcodes class>>initialize  comment #CogAbstractInstruction  class comment #CogRV64Compiler>>initializeAbstractRegisters  #CogAbstractRegisters  class comment #Cogit class>>structureOfACogMethod & "documentation" method categoryAnd of course the README.md at:     https://github.com/OpenSmalltalk/opensmalltalk-vm'! !!CogRV64Compiler class methodsFor: 'documentation' stamp: 'KenD 7/15/2026 12:51'!registerUse^'32 Integer and 32 Float Registers======================C ABI:  SEE #CogRV64Compile>>initilizeRV64RegisterAliases====x0 = ZERO [hardwired]x1 = Return Addressx2 = Stack Pointer [callee]x3 = Globals Pointerx4 = Thread Pointerx5..x7 = T0..T2 Temporariesx8 = S0 = FP  Frame Pointer [callee]x9 = S1  Saved [callee]x10..x17 = A0..A7    Integer Args ; A0..A1 return valuesx18..x27 = S2..S11  Saved [callee]x28..x31 = T3..T6  Temporariesf0..f7 = FT0..FT7 Float Tempsf8..f9 = FS0..FS1 Fl